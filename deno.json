{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "cli": "deno run --allow-net --allow-write cli.ts",
    "compile": "deno compile --allow-net --allow-write --output dist/cloakscan cli.ts",
    "compile:all": "deno task compile:mac-arm && deno task compile:mac-x64 && deno task compile:linux && deno task compile:windows",
    "compile:mac-arm": "deno compile --allow-net --allow-write --target aarch64-apple-darwin --output dist/cloakscan-macos-arm64 cli.ts",
    "compile:mac-x64": "deno compile --allow-net --allow-write --target x86_64-apple-darwin --output dist/cloakscan-macos-x64 cli.ts",
    "compile:linux": "deno compile --allow-net --allow-write --target x86_64-unknown-linux-gnu --output dist/cloakscan-linux-x64 cli.ts",
    "compile:windows": "deno compile --allow-net --allow-write --target x86_64-pc-windows-msvc --output dist/cloakscan-windows-x64.exe cli.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "@std/cli": "jsr:@std/cli@^1.0.17",
    "@std/fmt": "jsr:@std/fmt@^1.0.8"
  },
  "fmt": {
    "lineWidth": 100
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
